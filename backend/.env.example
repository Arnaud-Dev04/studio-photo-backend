# Base de données Supabase
DATABASE_URL=postgresql://postgres:VOTRE_MOT_DE_PASSE@db.xxxxx.supabase.co:5432/postgres

# Cloudinary
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# JWT
JWT_SECRET_KEY=votre_secret_jwt_tres_long_et_aleatoire

# Flask-Mail (Gmail ou autre SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=votre_email@gmail.com
MAIL_PASSWORD=votre_mot_de_passe_application
MAIL_DEFAULT_SENDER=votre_email@gmail.com

# Redis (pour Celery)
REDIS_URL=redis://default:VOTRE_MOT_DE_PASSE@redis-xxxxx.c1.us-east-1-2.ec2.redns.redis-cloud.com:6379

# Firebase Cloud Messaging
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
